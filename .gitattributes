# Normalize line endings: text files stored as LF in the repo.
* text=auto eol=lf

# Explicitly treat these as text.
*.py    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf

# Binary assets — never touch.
*.pdf   binary
*.db    binary
*.png   binary
*.jpg   binary
